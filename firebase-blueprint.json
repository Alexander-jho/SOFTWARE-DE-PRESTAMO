{
  "entities": {
    "Loan": {
      "title": "Loan",
      "description": "Represents a money loan granted to a client.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "UID of the user who owns the loan" },
        "clientName": { "type": "string", "description": "Full name of the client" },
        "clientPhoto": { "type": "string", "description": "Base64 string or URL of the client photo" },
        "principal": { "type": "number", "description": "Initial loan amount" },
        "interestRate": { "type": "number", "description": "Interest rate percentage" },
        "totalToPay": { "type": "number", "description": "Total amount to be paid (principal + interest)" },
        "remainingBalance": { "type": "number", "description": "Amount remaining to be fully paid" },
        "totalPaid": { "type": "number", "description": "Total amount paid so far" },
        "startDate": { "type": "string", "format": "date-time", "description": "Loan start date" },
        "dueDate": { "type": "string", "format": "date-time", "description": "Loan due date" },
        "status": { "type": "string", "enum": ["active", "overdue", "paid"], "description": "Current status of the loan" },
        "moraConfig": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["fixed", "daily"] },
            "value": { "type": "number" }
          },
          "required": ["type", "value"]
        },
        "currentMoraCharge": { "type": "number", "description": "Accumulated late fees" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "principal", "interestRate", "totalToPay", "remainingBalance", "totalPaid", "startDate", "dueDate", "status", "moraConfig", "createdAt", "updatedAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Represents a single payment (abono) made towards a loan.",
      "type": "object",
      "properties": {
        "loanId": { "type": "string" },
        "ownerId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["loanId", "amount", "date"]
    }
  },
  "firestore": {
    "/loans/{loanId}": {
      "schema": "Loan",
      "description": "Main collection of loans."
    },
    "/loans/{loanId}/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Subcollection of payments for a specific loan."
    }
  }
}
